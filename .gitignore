# OpenClaw Docker
# ================
# SECURITY: This file protects sensitive data from being committed

# Python
__pycache__/
*.pyc
# ===================
# SENSITIVE DATA - NEVER COMMIT
# ===================

# Main config (contains auth tokens)
data/openclaw.json
data/openclaw.json.bak
data/update-check.json

# Device identity (contains PRIVATE KEYS)
data/identity/

# Workspace (managed by OpenClaw, may contain nested .git)
data/workspace/

# Device pairing (contains tokens)
data/devices/

# Logs (may contain sensitive info)
data/logs/

# Task database
data/tasks/

# Stock data - notification config (contains API keys)
data/stock-data/notifier.json
data/stock-data/cache/
data/stock-data/reports/

# Catch-all for any new sensitive files in data/
data/*.json
data/*.sqlite
data/*.db

# ===================
# SAFE TO COMMIT
# ===================

# Keep canvas for custom UI (no secrets)
!data/canvas/
!data/canvas/.gitkeep

# Keep stock skill code (no secrets)
!data/skills/
!data/skills/**

# Keep watchlist (user data, no secrets)
!data/stock-data/
!data/stock-data/watchlist.json
!data/stock-data/notifier.example.json

# ===================
# GENERAL IGNORES
# ===================

# Docker
*.log

# OS files
.DS_Store
Thumbs.db
*~

# Editor files
.vscode/settings.json
.idea/

# Environment files (if any)
.env
.env.*
!.env.example
data/stock-data/trading-rules.json
data/skills/china-stock/trading.py
data/cron/runs/*.jsonl
